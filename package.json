  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.3",
  "scripts": {
    "prisma:push": "dotenv -e .env.local -- prisma db push",
    "prisma:reset": "dotenv -e .env.local -- prisma migrate reset",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "start:docker": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "clean:install": "rm -rf node_modules && rm -rf .next && rm bun.lock && bun install"
