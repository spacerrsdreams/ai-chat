generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
  runtime  = "vercel-edge"
}

datasource db {
  provider = "postgresql"
}

model Chat {
  id        String    @id @default(cuid())
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id        String      @id
  chatId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      MessageRole
  parts     Json
  createdAt DateTime    @default(now())

  @@index([chatId, createdAt])
}

enum MessageRole {
  user
  assistant
  system
}

model GenerationJob {
  id           String              @id @default(cuid())
  status       GenerationJobStatus @default(PENDING)
  kind         GenerationJobKind
  prompt       String
  resultUrl    String?
  resultText   String?
  errorMessage String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([createdAt(sort: Desc)])
}

enum GenerationJobStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum GenerationJobKind {
  image
  text
}
